# ============================================
# Marzban Security Bot - Configuration
# ============================================
# Скопируйте в .env и заполните значения
# ============================================

# --- Telegram Bot ---
# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID администраторов через запятую (получить через @userinfobot)
ADMIN_USER_IDS=123456789

# --- Marzban Panels ---
# Автоопределение работает по умолчанию!
# Для нескольких панелей: имя_контейнера:URL через запятую
# MULTI_PANELS=marzban-marzban-1:https://panel1.com,marzban2-marzban-1:https://panel2.com

# API токен Marzban (необязательно, для управления пользователями)
# Получить: Settings -> Subscription -> External Link
# MARZBAN_API_TOKEN_MARZBAN_MARBAN_1=your_api_token

# --- Security ---
MAX_LOGIN_ATTEMPTS=3
BAN_TIME_WINDOW=300
AUTOBAN_ENABLED=true

# --- Notifications ---
NOTIFY_ON_401=true
NOTIFY_ON_BAN=true
NOTIFY_ON_HIGH_CPU=true
NOTIFY_ON_HIGH_RAM=true
CPU_THRESHOLD=80
RAM_THRESHOLD=90
CONNECTIONS_THRESHOLD=500

# --- Monitoring ---
MONITOR_INTERVAL=3
SYSTEM_CHECK_INTERVAL=30

# --- GeoIP ---
GEOIP_ENABLED=true

# --- Backups ---
BACKUP_DIR=/opt/marzban-security-bot/backups
AUTO_BACKUP_ENABLED=false
BACKUP_INTERVAL_HOURS=24

# --- Language ---
# Поддерживается: ru, en, fa
LANGUAGE=ru

# --- Debug ---
DRY_RUN=false
VERBOSE=false
